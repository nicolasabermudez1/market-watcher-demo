# === REQUIRED ===
GEMINI_API_KEY=AIzaSy...           # Google AI Studio key — get from https://aistudio.google.com/apikey

# === OPTIONAL ===
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash-lite

# === DEMO CONFIG ===
DEMO_PORT_STREAMLIT=8501
DEMO_PORT_FASTAPI=8000
DEMO_LOG_LEVEL=INFO
DEMO_TRACE_DIR=data/runs

# === SEARCH (only if you enable the Brave fallback in config.toml) ===
BRAVE_SEARCH_API_KEY=              # optional — needed only if use_brave_fallback = true
